# === Sentinel runtime config ===
PORT=8001
GEMINI_API_KEY=<your-gemini-key>
GOOGLE_GENAI_USE_VERTEXAI=False
MONGO_URI=<mongodb-srv-uri>

# === Track 3 — GitLab MCP ===
GITLAB_PAT=<gitlab-personal-access-token>

# === Track 4 — Arize AX ===
ARIZE_SPACE_ID=<arize-space-id>
ARIZE_API_KEY=<arize-api-key>
ARIZE_PROJECT_NAME=sentinel-surveillance
ARIZE_COLLECTOR_ENDPOINT=https://otlp.arize.com/v1/traces

# === Track 5 — Dynatrace (OTLP exporter) ===
DT_ENVIRONMENT_URL=https://<tenant-id>.live.dynatrace.com
DT_API_TOKEN=<dt0c01.*-token-with-otlp-ingest-scope>
DT_ENVIRONMENT_ID=<tenant-id>
SENTINEL_VERSION=5.0.0

# === Track 5 — Dynatrace MCP (Platform Token, NEW) ===
DT_PLATFORM_TOKEN=<dt0s16.*-platform-token>
DT_ENVIRONMENT=https://<tenant-id>.apps.dynatrace.com
DT_GRAIL_QUERY_BUDGET_GB=10
